{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "greenhouse",
    "name": "Greenhouse",
    "author": "Claudette",
    "version": "2.1.0",
    "scheme": "dark",
    "description": "Biophilic sanctuary — mossy forest-floor black cradled in saffron golden-hour light filtered through greenhouse glass. Warm bark-brown shadows, organic radii, leaf silhouettes in the corners.",
    "stylesheet": "stylesheets/greenhouse.css",
    "preview": {
      "background": "#0e1310",
      "surface": "#1f2a24",
      "accent": "#e8a53c",
      "text": "#ecdcc0"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#0e1310",
      "sidebar-bg": "#141a16",
      "sidebar-border": "#2a332b",
      "panel-bg": "#141a16",
      "surface-bg": "#1f2a24",
      "sunken-bg": "#090d0b",
      "text-primary": "#ecdcc0",
      "text-muted": "#c6b79a",
      "text-dim": "#9a8e76",
      "text-faint": "#70664f",
      "text-separator": "#3d4539",
      "accent-primary": "#e8a53c",
      "accent-primary-rgb": "232, 165, 60",
      "accent-dim": "#b8822a",
      "accent-bg": "rgba(232, 165, 60, 0.10)",
      "accent-bg-strong": "rgba(232, 165, 60, 0.22)",
      "accent-glow": "0 0 2px rgba(255, 224, 160, 0.55), 0 0 18px rgba(232, 165, 60, 0.50), 0 0 46px rgba(232, 165, 60, 0.22), 0 0 88px rgba(127, 179, 138, 0.10)",
      "hover-bg": "rgba(236, 220, 192, 0.065)",
      "hover-bg-subtle": "rgba(236, 220, 192, 0.035)",
      "selected-bg": "rgba(232, 165, 60, 0.14)",
      "divider": "#2a332b",
      "status-running": "#e8a53c",
      "status-idle": "#9a8e76",
      "status-stopped": "#c0543a",
      "badge-done": "#7fb38a",
      "badge-plan": "#b09acb",
      "badge-ask": "#d8813e",
      "diff-added-bg": "rgba(127, 179, 138, 0.16)",
      "diff-removed-bg": "rgba(192, 84, 58, 0.17)",
      "diff-added-text": "#a3d2ab",
      "diff-removed-text": "#d47a5a",
      "diff-hunk-header": "#c1a678",
      "diff-line-number": "#70664f",
      "chat-user-bg": "rgba(236, 220, 192, 0.035)",
      "chat-system-bg": "rgba(232, 165, 60, 0.06)",
      "chat-input-bg": "#0b100d",
      "chat-header-bg": "#141a16",
      "terminal-tab-bg": "#141a16",
      "terminal-tab-active-bg": "#1f2a24",
      "terminal-bg": "#0a0f0c",
      "terminal-fg": "#ecdcc0",
      "terminal-cursor": "#e8a53c",
      "terminal-selection": "rgba(232, 165, 60, 0.26)",
      "toolbar-active": "rgba(232, 165, 60, 0.18)",
      "toolbar-active-text": "#f1b655",
      "error-bg": "rgba(192, 84, 58, 0.11)",
      "error-border": "rgba(192, 84, 58, 0.42)",
      "error-hover": "rgba(192, 84, 58, 0.18)",
      "overlay-bg": "rgba(14, 19, 16, 0.66)",
      "overlay-bg-heavy": "rgba(9, 13, 11, 0.86)",
      "canvas-atmosphere": "radial-gradient(60% 45% at 78% -8%, rgba(232, 165, 60, 0.18), transparent 58%), radial-gradient(80% 55% at 82% 10%, rgba(255, 206, 120, 0.08), transparent 70%), radial-gradient(100% 70% at 14% 110%, rgba(72, 110, 80, 0.10), transparent 60%), radial-gradient(160% 110% at 50% 42%, transparent 40%, rgba(4, 8, 6, 0.55) 100%)",
      "rim-light": "inset 0 1px 0 rgba(236, 220, 192, 0.055)",
      "rim-light-strong": "inset 0 1px 0 rgba(232, 165, 60, 0.14), inset 0 -1px 0 rgba(20, 10, 4, 0.42)",
      "selection-bg": "rgba(232, 165, 60, 0.32)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(38, 22, 8, 0.55), 0 0 0 1px rgba(88, 60, 28, 0.18)",
      "shadow-md": "0 8px 20px rgba(38, 22, 8, 0.55), 0 2px 6px rgba(38, 22, 8, 0.42), 0 0 0 1px rgba(88, 60, 28, 0.20)",
      "shadow-lg": "0 18px 44px rgba(38, 22, 8, 0.68), 0 6px 14px rgba(38, 22, 8, 0.48), 0 0 0 1px rgba(88, 60, 28, 0.24)",
      "shadow-card-hover": "0 14px 32px rgba(38, 22, 8, 0.62), 0 0 0 1px rgba(232, 165, 60, 0.35), 0 0 28px rgba(232, 165, 60, 0.22)",
      "well-shadow": "inset 0 2px 10px rgba(0, 0, 0, 0.58), inset 0 -1px 0 rgba(236, 220, 192, 0.04), inset 0 0 0 1px rgba(88, 60, 28, 0.15)",
      "composer-ring": "inset 0 0 0 1px rgba(88, 60, 28, 0.32), inset 0 1px 0 rgba(236, 220, 192, 0.05)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(232, 165, 60, 0.72), inset 0 1px 0 rgba(255, 224, 160, 0.18), 0 0 0 3px rgba(232, 165, 60, 0.14), 0 10px 26px rgba(38, 22, 8, 0.55), 0 0 40px rgba(232, 165, 60, 0.22)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.4",
      "line-height-normal": "1.68",
      "line-height-relaxed": "1.84",
      "letter-spacing-tight": "-0.003em",
      "letter-spacing-wide": "0.09em"
    },
    "radius": {
      "radius-sm": "8px",
      "radius-md": "14px",
      "radius-lg": "22px",
      "radius-pill": "999px",
      "border-radius": "14px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "18px",
      "space-xl": "28px"
    },
    "motion": {
      "transition-fast": "0.20s cubic-bezier(0.22, 1, 0.36, 1)",
      "transition-normal": "0.32s cubic-bezier(0.22, 1, 0.36, 1)",
      "transition-slow": "0.56s cubic-bezier(0.22, 1, 0.36, 1)",
      "ease-standard": "cubic-bezier(0.22, 1, 0.36, 1)",
      "ease-accelerate": "cubic-bezier(0.55, 0, 1, 0.45)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.25, 1)",
      "transition-hover": "0.22s ease",
      "transition-emphasis": "0.8s ease"
    },
    "layout": {
      "scrollbar-width": "10px",
      "scrollbar-thumb-bg": "rgba(236, 220, 192, 0.08)",
      "scrollbar-thumb-hover-bg": "rgba(232, 165, 60, 0.32)",
      "focus-ring": "0 0 0 2px rgba(232, 165, 60, 0.66), 0 0 20px rgba(232, 165, 60, 0.34)",
      "chat-max-width": "740px",
      "turn-gap": "24px",
      "canvas-padding-inline": "42px",
      "composer-min-height": "78px",
      "composer-padding-y": "16px",
      "sidebar-item-padding-y": "8px"
    },
    "border": {
      "border-thin": "1px",
      "border-medium": "2px"
    },
    "icon": {
      "icon-md": "16px",
      "icon-lg": "19px"
    },
    "control": {
      "control-height-md": "33px",
      "control-height-lg": "40px"
    },
    "component": {
      "card-padding": "20px",
      "menu-item-padding-y": "9px"
    },
    "shape": {
      "user-msg-padding": "10px 16px 10px 20px",
      "user-msg-chrome": "inset 4px 0 0 #e8a53c",
      "user-msg-bg": "rgba(232, 165, 60, 0.05)",
      "role-label-glyph": "'›'",
      "role-label-glyph-color": "#e8a53c",
      "sidebar-selected-chrome": "inset 4px 0 0 #e8a53c",
      "chat-header-chrome": "0 1px 0 rgba(232, 165, 60, 0.22)"
    }
  }
}

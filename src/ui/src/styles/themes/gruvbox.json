{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "gruvbox",
    "name": "Gruvbox",
    "author": "Claudette",
    "version": "2.0.0",
    "scheme": "dark",
    "description": "Gruvbox Hard \u2014 canonical #1d2021 bg, ochre ember on worn-notebook paper. Earthy, developer-beloved.",
    "stylesheet": "stylesheets/gruvbox.css",
    "preview": {
      "background": "#1d2021",
      "surface": "#32302f",
      "accent": "#fe8019",
      "text": "#ebdbb2"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#1d2021",
      "sidebar-bg": "#1b1e1f",
      "sidebar-border": "#3c3836",
      "panel-bg": "#282828",
      "surface-bg": "#32302f",
      "sunken-bg": "#141617",
      "text-primary": "#ebdbb2",
      "text-muted": "#bdae93",
      "text-dim": "#a89984",
      "text-faint": "#7c6f64",
      "text-separator": "#504945",
      "accent-primary": "#fe8019",
      "accent-primary-rgb": "254, 128, 25",
      "accent-dim": "#d65d0e",
      "accent-bg": "rgba(254, 128, 25, 0.09)",
      "accent-bg-strong": "rgba(254, 128, 25, 0.22)",
      "accent-glow": "0 0 1px rgba(250, 189, 47, 0.65), 0 0 10px rgba(254, 128, 25, 0.50), 0 0 28px rgba(214, 93, 14, 0.22), 0 0 60px rgba(214, 93, 14, 0.09)",
      "hover-bg": "rgba(235, 219, 178, 0.06)",
      "hover-bg-subtle": "rgba(235, 219, 178, 0.03)",
      "selected-bg": "rgba(254, 128, 25, 0.15)",
      "divider": "#3c3836",
      "status-running": "#fe8019",
      "status-idle": "#928374",
      "status-stopped": "#cc241d",
      "badge-done": "#b8bb26",
      "badge-plan": "#83a598",
      "badge-ask": "#fabd2f",
      "diff-added-bg": "rgba(184, 187, 38, 0.14)",
      "diff-removed-bg": "rgba(251, 73, 52, 0.13)",
      "diff-added-text": "#b8bb26",
      "diff-removed-text": "#fb4934",
      "diff-hunk-header": "#fabd2f",
      "diff-line-number": "#7c6f64",
      "chat-user-bg": "rgba(235, 219, 178, 0.028)",
      "chat-system-bg": "rgba(254, 128, 25, 0.06)",
      "chat-input-bg": "#141617",
      "chat-header-bg": "#1b1e1f",
      "terminal-tab-bg": "#1b1e1f",
      "terminal-tab-active-bg": "#32302f",
      "terminal-bg": "#141617",
      "terminal-fg": "#ebdbb2",
      "terminal-cursor": "#fe8019",
      "terminal-selection": "rgba(254, 128, 25, 0.30)",
      "toolbar-active": "rgba(254, 128, 25, 0.18)",
      "toolbar-active-text": "#fabd2f",
      "error-bg": "rgba(204, 36, 29, 0.10)",
      "error-border": "rgba(204, 36, 29, 0.42)",
      "error-hover": "rgba(204, 36, 29, 0.16)",
      "overlay-bg": "rgba(14, 16, 17, 0.70)",
      "overlay-bg-heavy": "rgba(14, 16, 17, 0.90)",
      "canvas-atmosphere": "radial-gradient(80% 52% at 50% -6%, rgba(254, 128, 25, 0.09), transparent 58%), radial-gradient(70% 42% at 50% 0%, rgba(250, 189, 47, 0.05), transparent 72%), radial-gradient(120% 80% at 50% 100%, rgba(14, 16, 17, 0.55), transparent 60%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 160'><filter id='p'><feTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.92  0 0 0 0 0.86  0 0 0 0 0.70  0 0 0 0.045 0'/></filter><rect width='100%25' height='100%25' filter='url(%23p)'/></svg>\")",
      "rim-light": "inset 0 1px 0 rgba(235, 219, 178, 0.06)",
      "rim-light-strong": "inset 0 1px 0 rgba(250, 189, 47, 0.20), inset 0 -1px 0 rgba(14, 16, 17, 0.55)",
      "selection-bg": "rgba(254, 128, 25, 0.34)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(14, 16, 17, 0.60), 0 0 0 1px rgba(254, 128, 25, 0.04)",
      "shadow-md": "0 10px 28px -12px rgba(14, 16, 17, 0.82), 0 2px 6px -2px rgba(29, 32, 33, 0.50), 0 0 0 1px rgba(254, 128, 25, 0.05)",
      "shadow-lg": "0 24px 52px -18px rgba(14, 16, 17, 0.90), 0 8px 16px -6px rgba(29, 32, 33, 0.60), 0 0 0 1px rgba(254, 128, 25, 0.08)",
      "shadow-card-hover": "0 16px 36px -14px rgba(14, 16, 17, 0.86), 0 4px 10px -2px rgba(29, 32, 33, 0.55), 0 0 0 1px rgba(254, 128, 25, 0.40), 0 0 28px rgba(250, 189, 47, 0.16)",
      "well-shadow": "inset 0 2px 10px rgba(8, 10, 11, 0.78), inset 0 -1px 0 rgba(235, 219, 178, 0.045), inset 0 0 0 1px rgba(254, 128, 25, 0.05)",
      "composer-ring": "inset 0 0 0 1px rgba(214, 93, 14, 0.22), inset 0 1px 0 rgba(235, 219, 178, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(254, 128, 25, 0.85), inset 0 1px 0 rgba(250, 189, 47, 0.24), 0 0 0 3px rgba(254, 128, 25, 0.18), 0 10px 28px -8px rgba(214, 93, 14, 0.34), 0 0 40px rgba(250, 189, 47, 0.10)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.58",
      "line-height-relaxed": "1.72",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.06em"
    },
    "radius": {
      "radius-sm": "3px",
      "radius-md": "6px",
      "radius-lg": "10px",
      "radius-pill": "999px",
      "border-radius": "6px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.14s cubic-bezier(0.2, 0.8, 0.2, 1)",
      "transition-normal": "0.22s cubic-bezier(0.2, 0.8, 0.2, 1)",
      "transition-slow": "0.34s cubic-bezier(0.2, 0.8, 0.2, 1)",
      "ease-standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.12s ease"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(254, 128, 25, 0.14)",
      "scrollbar-thumb-hover-bg": "rgba(254, 128, 25, 0.45)",
      "focus-ring": "0 0 0 1px rgba(250, 189, 47, 0.55), 0 0 0 3px rgba(254, 128, 25, 0.55), 0 6px 18px rgba(214, 93, 14, 0.25)",
      "chat-max-width": "960px",
      "turn-gap": "14px",
      "canvas-padding-inline": "28px",
      "composer-min-height": "60px"
    },
    "border": {
      "border-thin": "1px",
      "border-medium": "2px"
    },
    "icon": {
      "icon-md": "16px"
    },
    "control": {
      "control-height-md": "32px"
    },
    "component": {
      "menu-item-padding-x": "12px"
    }
  }
}

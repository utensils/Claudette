{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "one-dark",
    "name": "One Dark",
    "author": "Atom (port)",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Canonical Atom One Dark — slate charcoal (#282c34) with editor-blue (#61afef) accent, mauve and green syntax accents, dev-dense information density.",
    "stylesheet": "stylesheets/one-dark.css",
    "preview": {
      "background": "#282c34",
      "surface": "#2c313c",
      "accent": "#61afef",
      "text": "#abb2bf"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#282c34",
      "sidebar-bg": "#21252b",
      "sidebar-border": "#3a3f4b",
      "panel-bg": "#2c313c",
      "surface-bg": "#323842",
      "sunken-bg": "#1b1f24",
      "text-primary": "#abb2bf",
      "text-muted": "#9099a9",
      "text-dim": "#7a8290",
      "text-faint": "#5c6370",
      "text-separator": "#3a3f4b",
      "accent-primary": "#61afef",
      "accent-primary-rgb": "97, 175, 239",
      "accent-dim": "#4a8fc9",
      "accent-bg": "rgba(97, 175, 239, 0.10)",
      "accent-bg-strong": "rgba(97, 175, 239, 0.22)",
      "accent-glow": "0 0 1px rgba(198, 222, 250, 0.68), 0 0 12px rgba(97, 175, 239, 0.52), 0 0 30px rgba(86, 182, 194, 0.22), 0 0 64px rgba(198, 120, 221, 0.10)",
      "hover-bg": "rgba(171, 178, 191, 0.05)",
      "hover-bg-subtle": "rgba(171, 178, 191, 0.028)",
      "selected-bg": "rgba(97, 175, 239, 0.15)",
      "divider": "#3a3f4b",

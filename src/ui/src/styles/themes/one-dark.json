      "terminal-fg": "#abb2bf",
      "terminal-cursor": "#61afef",
      "terminal-selection": "rgba(97, 175, 239, 0.28)",
      "toolbar-active": "rgba(97, 175, 239, 0.20)",
      "toolbar-active-text": "#8cc4f4",
      "error-bg": "rgba(224, 108, 117, 0.10)",
      "error-border": "rgba(224, 108, 117, 0.40)",
      "error-hover": "rgba(224, 108, 117, 0.16)",
      "overlay-bg": "rgba(14, 16, 20, 0.72)",
      "overlay-bg-heavy": "rgba(14, 16, 20, 0.90)",
      "canvas-atmosphere": "radial-gradient(90% 50% at 50% -4%, rgba(97, 175, 239, 0.10), transparent 60%), radial-gradient(70% 30% at 25% -2%, rgba(198, 120, 221, 0.06), transparent 72%), radial-gradient(70% 30% at 75% -2%, rgba(86, 182, 194, 0.07), transparent 72%), radial-gradient(120% 80% at 50% 100%, rgba(14, 16, 20, 0.55), transparent 60%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'><filter id='o'><feTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='2' stitchTiles='stitch' seed='9'/><feColorMatrix values='0 0 0 0 0.67  0 0 0 0 0.70  0 0 0 0 0.75  0 0 0 0.035 0'/></filter><rect width='100%25' height='100%25' filter='url(%23o)'/></svg>\")",

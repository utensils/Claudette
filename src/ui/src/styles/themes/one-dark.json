      "shadow-card-hover": "0 16px 36px -14px rgba(10, 12, 16, 0.85), 0 4px 10px -2px rgba(27, 31, 36, 0.58), 0 0 0 1px rgba(97, 175, 239, 0.42), 0 0 28px rgba(97, 175, 239, 0.16)",
      "well-shadow": "inset 0 2px 10px rgba(5, 7, 10, 0.78), inset 0 -1px 0 rgba(171, 178, 191, 0.04), inset 0 0 0 1px rgba(97, 175, 239, 0.06)",
      "composer-ring": "inset 0 0 0 1px rgba(97, 175, 239, 0.22), inset 0 1px 0 rgba(171, 178, 191, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(97, 175, 239, 0.88), inset 0 1px 0 rgba(198, 222, 250, 0.22), 0 0 0 3px rgba(97, 175, 239, 0.20), 0 10px 28px -8px rgba(74, 143, 201, 0.32), 0 0 40px rgba(97, 175, 239, 0.12)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.28",
      "line-height-normal": "1.52",
      "line-height-relaxed": "1.68",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "3px",
      "radius-md": "5px",
      "radius-lg": "8px",
      "radius-pill": "999px",
      "border-radius": "5px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.10s ease",
      "transition-normal": "0.18s ease",
      "transition-slow": "0.28s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(97, 175, 239, 0.16)",
      "scrollbar-thumb-hover-bg": "rgba(97, 175, 239, 0.44)",
      "focus-ring": "0 0 0 1px rgba(198, 222, 250, 0.55), 0 0 0 3px rgba(97, 175, 239, 0.55), 0 6px 18px rgba(97, 175, 239, 0.26)",
      "chat-max-width": "1020px",
      "turn-gap": "14px",
      "composer-min-height": "58px",
      "composer-padding-y": "12px",
      "canvas-padding-inline": "28px",
      "sidebar-item-padding-y": "5px"
    },
    "border": {
      "border-thin": "1px"
    },
    "icon": {
      "icon-md": "15px"
    },
    "control": {
      "control-height-md": "30px"
    }

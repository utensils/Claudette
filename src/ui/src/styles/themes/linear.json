{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "linear",
    "name": "Linear",
    "author": "Claudette",
    "version": "2.0.0",
    "scheme": "dark",
    "description": "Tech editorial \u2014 Linear.app's signature indigo (#5e6ad2) over charcoal-black, crisp hairlines, mesh-gradient hero, snappy transitions.",
    "stylesheet": "stylesheets/linear.css",
    "preview": {
      "background": "#08080c",
      "surface": "#1a1a24",
      "accent": "#5e6ad2",
      "text": "#e5e5ea"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#08080c",
      "sidebar-bg": "#0b0b11",
      "sidebar-border": "#1e1e2e",
      "panel-bg": "#101018",
      "surface-bg": "#1a1a24",
      "sunken-bg": "#050508",
      "text-primary": "#e5e5ea",
      "text-muted": "#a8a8b4",
      "text-dim": "#7b7b8b",
      "text-faint": "#50505e",
      "text-separator": "#1e1e2e",
      "accent-primary": "#5e6ad2",
      "accent-primary-rgb": "94, 106, 210",
      "accent-dim": "#4852a8",
      "accent-bg": "rgba(94, 106, 210, 0.09)",
      "accent-bg-strong": "rgba(94, 106, 210, 0.22)",
      "accent-glow": "0 0 1px rgba(210, 210, 255, 0.70), 0 0 10px rgba(94, 106, 210, 0.55), 0 0 28px rgba(94, 106, 210, 0.22), 0 0 60px rgba(94, 106, 210, 0.08)",
      "hover-bg": "rgba(229, 229, 234, 0.045)",
      "hover-bg-subtle": "rgba(229, 229, 234, 0.025)",
      "selected-bg": "rgba(94, 106, 210, 0.15)",
      "divider": "#1c1c28",
      "status-running": "#5e6ad2",
      "status-idle": "#7b7b8b",
      "status-stopped": "#e06a7a",
      "badge-done": "#68d3b5",
      "badge-plan": "#5e6ad2",
      "badge-ask": "#e8c97a",
      "diff-added-bg": "rgba(104, 211, 181, 0.10)",
      "diff-removed-bg": "rgba(224, 106, 122, 0.12)",
      "diff-added-text": "#8fe5c8",
      "diff-removed-text": "#ee8a9a",
      "diff-hunk-header": "#8ab2f8",
      "diff-line-number": "#50505e",
      "chat-user-bg": "rgba(229, 229, 234, 0.022)",
      "chat-system-bg": "rgba(94, 106, 210, 0.055)",
      "chat-input-bg": "#060609",
      "chat-header-bg": "#0b0b11",
      "terminal-tab-bg": "#0b0b11",
      "terminal-tab-active-bg": "#1a1a24",
      "terminal-bg": "#050508",
      "terminal-fg": "#e5e5ea",
      "terminal-cursor": "#5e6ad2",
      "terminal-selection": "rgba(94, 106, 210, 0.28)",
      "toolbar-active": "rgba(94, 106, 210, 0.18)",
      "toolbar-active-text": "#9aa4f0",
      "error-bg": "rgba(224, 106, 122, 0.10)",
      "error-border": "rgba(224, 106, 122, 0.38)",
      "error-hover": "rgba(224, 106, 122, 0.16)",
      "overlay-bg": "rgba(4, 4, 8, 0.72)",
      "overlay-bg-heavy": "rgba(4, 4, 8, 0.90)",
      "canvas-atmosphere": "radial-gradient(50% 45% at 8% -6%, rgba(94, 106, 210, 0.38), transparent 62%), radial-gradient(55% 50% at 92% -2%, rgba(138, 120, 230, 0.28), transparent 65%), radial-gradient(60% 60% at 88% 95%, rgba(94, 106, 210, 0.20), transparent 68%), radial-gradient(55% 55% at 12% 100%, rgba(138, 120, 230, 0.16), transparent 68%), radial-gradient(45% 45% at 50% 50%, rgba(94, 106, 210, 0.06), transparent 70%)",
      "rim-light": "inset 0 1px 0 rgba(229, 229, 234, 0.045)",
      "rim-light-strong": "inset 0 1px 0 rgba(154, 164, 240, 0.14), inset 0 -1px 0 rgba(4, 4, 8, 0.55)",
      "selection-bg": "rgba(94, 106, 210, 0.34)"
    },
    "elevation": {
      "shadow-sm": "0 1px 0 rgba(4, 4, 8, 0.80), 0 0 0 1px rgba(94, 106, 210, 0.06)",
      "shadow-md": "0 8px 24px -12px rgba(4, 4, 8, 0.85), 0 2px 4px -1px rgba(10, 10, 22, 0.55), 0 0 0 1px rgba(94, 106, 210, 0.08)",
      "shadow-lg": "0 20px 48px -18px rgba(4, 4, 8, 0.92), 0 6px 14px -4px rgba(10, 10, 22, 0.62), 0 0 0 1px rgba(94, 106, 210, 0.12)",
      "shadow-card-hover": "0 14px 32px -14px rgba(4, 4, 8, 0.88), 0 4px 8px -2px rgba(10, 10, 22, 0.58), 0 0 0 1px rgba(94, 106, 210, 0.48), 0 0 24px rgba(94, 106, 210, 0.18)",
      "well-shadow": "inset 0 1px 0 rgba(229, 229, 234, 0.04), inset 0 0 0 1px rgba(94, 106, 210, 0.06)",
      "composer-ring": "inset 0 0 0 1px rgba(94, 106, 210, 0.22), inset 0 1px 0 rgba(229, 229, 234, 0.05)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(94, 106, 210, 0.88), inset 0 1px 0 rgba(210, 210, 255, 0.22), 0 0 0 3px rgba(94, 106, 210, 0.20), 0 8px 24px -8px rgba(94, 106, 210, 0.36), 0 0 36px rgba(94, 106, 210, 0.12)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.26",
      "line-height-normal": "1.52",
      "line-height-relaxed": "1.66",
      "letter-spacing-tight": "-0.018em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "4px",
      "radius-md": "6px",
      "radius-lg": "8px",
      "radius-pill": "999px",
      "border-radius": "6px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.08s cubic-bezier(0.2, 0, 0.2, 1)",
      "transition-normal": "0.14s cubic-bezier(0.2, 0, 0.2, 1)",
      "transition-slow": "0.22s cubic-bezier(0.2, 0, 0.2, 1)",
      "ease-standard": "cubic-bezier(0.2, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.08s ease",
      "transition-emphasis": "0.4s ease"
    },
    "layout": {
      "scrollbar-width": "6px",
      "scrollbar-thumb-bg": "rgba(94, 106, 210, 0.14)",
      "scrollbar-thumb-hover-bg": "rgba(94, 106, 210, 0.45)",
      "focus-ring": "0 0 0 1px rgba(210, 210, 255, 0.55), 0 0 0 3px rgba(94, 106, 210, 0.55), 0 4px 12px rgba(94, 106, 210, 0.25)",
      "chat-max-width": "1100px",
      "turn-gap": "10px",
      "composer-min-height": "52px",
      "composer-padding-y": "12px",
      "canvas-padding-inline": "28px",
      "sidebar-item-padding-y": "5px",
      "sidebar-item-gap": "1px"
    },
    "border": {
      "border-thin": "1px",
      "border-medium": "1px",
      "border-thick": "2px"
    },
    "icon": {
      "icon-xs": "10px",
      "icon-sm": "12px",
      "icon-md": "14px",
      "icon-lg": "16px"
    },
    "control": {
      "control-height-sm": "22px",
      "control-height-md": "28px",
      "control-height-lg": "34px"
    },
    "component": {
      "control-padding-x": "10px",
      "control-padding-y": "5px",
      "menu-item-padding-y": "6px",
      "menu-item-padding-x": "10px",
      "card-padding": "14px"
    }
  }
}

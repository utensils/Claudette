      "error-border": "rgba(167, 58, 26, 0.40)",
      "error-hover": "rgba(167, 58, 26, 0.16)",
      "overlay-bg": "rgba(60, 40, 20, 0.38)",
      "overlay-bg-heavy": "rgba(40, 26, 12, 0.58)",
      "canvas-atmosphere": "conic-gradient(from 200deg at 50% 118%, rgba(255, 196, 110, 0.30) 0deg, rgba(245, 150, 70, 0.28) 26deg, rgba(210, 100, 40, 0.22) 52deg, rgba(150, 80, 40, 0.12) 88deg, rgba(80, 50, 24, 0.06) 130deg, rgba(80, 50, 24, 0.06) 230deg, rgba(150, 80, 40, 0.12) 272deg, rgba(245, 150, 70, 0.28) 334deg, rgba(255, 196, 110, 0.30) 360deg), radial-gradient(68% 40% at 50% 100%, rgba(255, 210, 130, 0.30), transparent 72%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 220 220'><filter id='p'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.40  0 0 0 0 0.24  0 0 0 0 0.10  0 0 0 0.055 0'/></filter><rect width='100%25' height='100%25' filter='url(%23p)'/></svg>\")",

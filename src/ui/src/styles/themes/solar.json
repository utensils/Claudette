      "shadow-card-hover": "0 14px 34px -12px rgba(80, 55, 30, 0.28), 0 2px 6px -1px rgba(80, 55, 30, 0.14), 0 0 0 1px rgba(178, 92, 24, 0.36)",
      "well-shadow": "inset 0 2px 8px rgba(80, 55, 30, 0.16), inset 0 1px 0 rgba(60, 40, 20, 0.06), inset 0 0 0 1px rgba(178, 92, 24, 0.06)",
      "composer-ring": "inset 0 0 0 1px rgba(101, 70, 35, 0.26), inset 0 1px 0 rgba(255, 240, 200, 0.55)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(178, 92, 24, 0.75), inset 0 1px 0 rgba(255, 240, 200, 0.60), 0 0 0 3px rgba(178, 92, 24, 0.14), 0 10px 24px -8px rgba(178, 92, 24, 0.28)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.32",
      "line-height-normal": "1.62",
      "line-height-relaxed": "1.76",
      "letter-spacing-tight": "-0.015em",
      "letter-spacing-wide": "0.06em"
    },
    "radius": {
      "radius-sm": "8px",
      "radius-md": "14px",
      "radius-lg": "22px",
      "radius-pill": "999px",
      "border-radius": "14px"
    },
    "spacing": {
      "space-xs": "5px",
      "space-sm": "10px",
      "space-md": "16px",
      "space-lg": "22px",
      "space-xl": "32px"
    },
    "motion": {
      "transition-fast": "0.14s cubic-bezier(0.3, 0.7, 0.2, 1)",
      "transition-normal": "0.22s cubic-bezier(0.3, 0.7, 0.2, 1)",
      "transition-slow": "0.34s cubic-bezier(0.3, 0.7, 0.2, 1)",
      "ease-standard": "cubic-bezier(0.3, 0.7, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.22s cubic-bezier(0.2, 0, 0, 1)",
      "transition-emphasis": "0.65s ease"
    },
    "layout": {
      "scrollbar-width": "10px",
      "scrollbar-thumb-bg": "rgba(101, 70, 35, 0.22)",
      "scrollbar-thumb-hover-bg": "rgba(178, 92, 24, 0.48)",
      "focus-ring": "0 0 0 1px rgba(255, 240, 200, 0.80), 0 0 0 3px rgba(178, 92, 24, 0.55), 0 6px 18px rgba(178, 92, 24, 0.22)",

{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "solar",
    "name": "Solar",
    "author": "James Brink",
    "version": "2.0.0",
    "scheme": "light",
    "description": "Editorial ivory paper and burnt-sienna wire \u2014 desert solstice at high noon.",
    "stylesheet": "stylesheets/solar.css",
    "preview": {
      "background": "#f6ead3",
      "surface": "#fbf2e1",
      "accent": "#b25c18",
      "text": "#2a1b0e"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "light",
      "app-bg": "#f6ead3",
      "sidebar-bg": "#efdfbd",
      "sidebar-border": "#d4b888",
      "panel-bg": "#f2e3c2",
      "surface-bg": "#fbf2e1",
      "sunken-bg": "#e8d4a8",
      "text-primary": "#2a1b0e",
      "text-muted": "#5b4226",
      "text-dim": "#86673f",
      "text-faint": "#ad8a5a",
      "text-separator": "#c9a974",
      "accent-primary": "#b25c18",

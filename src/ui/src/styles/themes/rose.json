      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.32",
      "line-height-normal": "1.66",
      "line-height-relaxed": "1.82",
      "letter-spacing-tight": "-0.008em",
      "letter-spacing-wide": "0.07em"

{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "riviera",
    "name": "Riviera",
    "author": "Claudette",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Mediterranean midnight — deep sea blue with coral sunset and turquoise tide, sun-bleached ivory text.",
    "stylesheet": "stylesheets/riviera.css",
    "preview": {
      "background": "#0c1e36",
      "surface": "#17304d",
      "accent": "#ff8b72",
      "text": "#f2e8d5"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#0c1e36",
      "sidebar-bg": "#102540",
      "sidebar-border": "#1c3557",
      "panel-bg": "#102540",
      "surface-bg": "#17304d",
      "sunken-bg": "#07142a",
      "text-primary": "#f2e8d5",
      "text-muted": "#b5ac96",
      "text-dim": "#85806f",
      "text-faint": "#575345",
      "text-separator": "#1c3557",
      "accent-primary": "#ff8b72",
      "accent-primary-rgb": "255, 139, 114",
      "accent-dim": "#d6654a",
      "accent-bg": "rgba(255, 139, 114, 0.10)",
      "accent-bg-strong": "rgba(255, 139, 114, 0.22)",
      "accent-glow": "0 0 1px rgba(255, 230, 218, 0.75), 0 0 10px rgba(255, 139, 114, 0.45), 0 0 28px rgba(125, 211, 192, 0.20)",
      "hover-bg": "rgba(242, 232, 213, 0.055)",
      "hover-bg-subtle": "rgba(242, 232, 213, 0.025)",
      "selected-bg": "rgba(255, 139, 114, 0.14)",
      "divider": "#1c3557",
      "status-running": "#ff8b72",
      "status-idle": "#85806f",
      "status-stopped": "#d6654a",
      "badge-done": "#7dd3c0",
      "badge-plan": "#5aa0d6",
      "badge-ask": "#f0c97d",
      "diff-added-bg": "rgba(125, 211, 192, 0.14)",
      "diff-removed-bg": "rgba(214, 101, 74, 0.14)",
      "diff-added-text": "#9ee3d2",
      "diff-removed-text": "#ff9278",
      "diff-hunk-header": "#f0c97d",
      "diff-line-number": "#575345",
      "chat-user-bg": "rgba(242, 232, 213, 0.025)",
      "chat-system-bg": "rgba(255, 139, 114, 0.06)",
      "chat-input-bg": "#07142a",
      "chat-header-bg": "#102540",
      "terminal-tab-bg": "#102540",
      "terminal-tab-active-bg": "#17304d",
      "terminal-bg": "#07142a",
      "terminal-fg": "#f2e8d5",
      "terminal-cursor": "#ff8b72",
      "terminal-selection": "rgba(255, 139, 114, 0.32)",
      "toolbar-active": "rgba(125, 211, 192, 0.18)",
      "toolbar-active-text": "#9ee3d2",
      "error-bg": "rgba(214, 101, 74, 0.12)",
      "error-border": "rgba(214, 101, 74, 0.45)",
      "error-hover": "rgba(214, 101, 74, 0.20)",
      "overlay-bg": "rgba(7, 20, 42, 0.72)",
      "overlay-bg-heavy": "rgba(7, 20, 42, 0.90)",
      "canvas-atmosphere": "radial-gradient(65% 45% at 92% 8%, rgba(255, 139, 114, 0.22), transparent 60%), radial-gradient(55% 40% at 4% 96%, rgba(125, 211, 192, 0.18), transparent 65%), radial-gradient(110% 70% at 50% 120%, rgba(7, 20, 42, 0.55), transparent 60%)",
      "rim-light": "inset 0 1px 0 rgba(242, 232, 213, 0.075)",
      "rim-light-strong": "inset 0 1px 0 rgba(125, 211, 192, 0.18), inset 0 -1px 0 rgba(7, 20, 42, 0.60)",
      "selection-bg": "rgba(255, 139, 114, 0.34)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(7, 20, 42, 0.60), 0 0 0 1px rgba(255, 139, 114, 0.05)",
      "shadow-md": "0 10px 26px -12px rgba(7, 20, 42, 0.78), 0 2px 6px -2px rgba(12, 30, 54, 0.50), 0 0 0 1px rgba(255, 139, 114, 0.05)",
      "shadow-lg": "0 24px 50px -18px rgba(7, 20, 42, 0.88), 0 8px 16px -6px rgba(12, 30, 54, 0.60), 0 0 0 1px rgba(255, 139, 114, 0.08)",
      "shadow-card-hover": "0 16px 36px -14px rgba(7, 20, 42, 0.85), 0 4px 10px -2px rgba(12, 30, 54, 0.55), 0 0 0 1px rgba(255, 139, 114, 0.36), 0 0 26px rgba(125, 211, 192, 0.18)",
      "well-shadow": "inset 0 2px 10px rgba(5, 14, 30, 0.72), inset 0 -1px 0 rgba(242, 232, 213, 0.045), inset 0 0 0 1px rgba(255, 139, 114, 0.05)",
      "composer-ring": "inset 0 0 0 1px rgba(255, 139, 114, 0.22), inset 0 1px 0 rgba(242, 232, 213, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(255, 139, 114, 0.80), inset 0 1px 0 rgba(255, 230, 218, 0.20), 0 0 0 3px rgba(255, 139, 114, 0.18), 0 10px 28px -8px rgba(255, 139, 114, 0.28), 0 0 40px rgba(125, 211, 192, 0.14)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.30",
      "line-height-normal": "1.62",
      "line-height-relaxed": "1.74",
      "letter-spacing-tight": "-0.010em",
      "letter-spacing-wide": "0.06em"
    },
    "radius": {
      "radius-sm": "6px",
      "radius-md": "10px",
      "radius-lg": "16px",
      "radius-pill": "999px",
      "border-radius": "10px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "9px",
      "space-md": "14px",
      "space-lg": "20px",
      "space-xl": "28px"
    },
    "motion": {
      "transition-fast": "0.16s cubic-bezier(0.3, 0.7, 0.2, 1)",
      "transition-normal": "0.24s cubic-bezier(0.3, 0.7, 0.2, 1)",
      "transition-slow": "0.36s cubic-bezier(0.3, 0.7, 0.2, 1)",
      "ease-standard": "cubic-bezier(0.3, 0.7, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.22s cubic-bezier(0.2, 0, 0, 1)",
      "transition-emphasis": "0.75s ease"
    },
    "layout": {
      "scrollbar-width": "9px",
      "scrollbar-thumb-bg": "rgba(255, 139, 114, 0.18)",
      "scrollbar-thumb-hover-bg": "rgba(125, 211, 192, 0.48)",
      "focus-ring": "0 0 0 1px rgba(255, 230, 218, 0.50), 0 0 0 3px rgba(255, 139, 114, 0.52), 0 6px 18px rgba(125, 211, 192, 0.22)",
      "chat-max-width": "860px",
      "turn-gap": "18px",
      "canvas-padding-inline": "42px",
      "composer-min-height": "84px",
      "composer-padding-y": "16px",
      "sidebar-item-padding-y": "8px"
    },
    "border": {
      "border-thin": "1px"
    },
    "icon": {
      "icon-md": "17px",
      "icon-lg": "20px"
    },
    "control": {
      "control-height-md": "34px",
      "control-height-lg": "42px"
    },
    "component": {
      "card-padding": "22px",
      "menu-item-padding-y": "10px",
      "menu-item-padding-x": "18px"
    }
  }
}

{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "catppuccin-mocha",
    "name": "Catppuccin Mocha",
    "author": "Catppuccin (port)",
    "version": "2.0.0",
    "scheme": "dark",
    "description": "Official Catppuccin Mocha \u2014 canonical base #1e1e2e, mauve/pink/rosewater bloom, four-corner pastel mesh with screen-blended fog.",
    "stylesheet": "stylesheets/catppuccin-mocha.css",
    "preview": {
      "background": "#1e1e2e",
      "surface": "#313244",
      "accent": "#cba6f7",
      "text": "#cdd6f4"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#1e1e2e",
      "sidebar-bg": "#181825",
      "sidebar-border": "#313244",
      "panel-bg": "#181825",
      "surface-bg": "#1e1e2e",
      "sunken-bg": "#11111b",
      "text-primary": "#cdd6f4",
      "text-muted": "#bac2de",
      "text-dim": "#a6adc8",
      "text-faint": "#7f849c",
      "text-separator": "#45475a",
      "accent-primary": "#cba6f7",
      "accent-primary-rgb": "203, 166, 247",
      "accent-dim": "#a786dc",
      "accent-bg": "rgba(203, 166, 247, 0.10)",
      "accent-bg-strong": "rgba(203, 166, 247, 0.22)",
      "accent-glow": "0 0 1px rgba(245, 224, 220, 0.72), 0 0 14px rgba(203, 166, 247, 0.55), 0 0 32px rgba(245, 194, 231, 0.26), 0 0 68px rgba(148, 226, 213, 0.10)",
      "hover-bg": "rgba(205, 214, 244, 0.05)",
      "hover-bg-subtle": "rgba(205, 214, 244, 0.028)",
      "selected-bg": "rgba(203, 166, 247, 0.16)",
      "divider": "#313244",
      "status-running": "#a6e3a1",
      "status-idle": "#7f849c",
      "status-stopped": "#f38ba8",
      "badge-done": "#a6e3a1",
      "badge-plan": "#cba6f7",
      "badge-ask": "#f9e2af",
      "diff-added-bg": "rgba(166, 227, 161, 0.14)",
      "diff-removed-bg": "rgba(243, 139, 168, 0.14)",
      "diff-added-text": "#b7e8b0",
      "diff-removed-text": "#f5a0b6",
      "diff-hunk-header": "#f5c2e7",
      "diff-line-number": "#7f849c",
      "chat-user-bg": "rgba(205, 214, 244, 0.025)",
      "chat-system-bg": "rgba(203, 166, 247, 0.06)",
      "chat-input-bg": "#11111b",
      "chat-header-bg": "#181825",
      "terminal-tab-bg": "#181825",
      "terminal-tab-active-bg": "#313244",
      "terminal-bg": "#11111b",
      "terminal-fg": "#cdd6f4",
      "terminal-cursor": "#f5e0dc",
      "terminal-selection": "rgba(203, 166, 247, 0.28)",
      "toolbar-active": "rgba(203, 166, 247, 0.20)",
      "toolbar-active-text": "#dcc3fc",
      "error-bg": "rgba(243, 139, 168, 0.11)",
      "error-border": "rgba(243, 139, 168, 0.40)",
      "error-hover": "rgba(243, 139, 168, 0.18)",
      "overlay-bg": "rgba(17, 17, 27, 0.72)",
      "overlay-bg-heavy": "rgba(17, 17, 27, 0.90)",
      "canvas-atmosphere": "radial-gradient(52% 38% at 12% 8%, rgba(245, 194, 231, 0.18), transparent 70%), radial-gradient(48% 35% at 88% 10%, rgba(203, 166, 247, 0.18), transparent 72%), radial-gradient(55% 40% at 20% 96%, rgba(137, 180, 250, 0.14), transparent 70%), radial-gradient(52% 38% at 82% 100%, rgba(148, 226, 213, 0.12), transparent 72%), radial-gradient(40% 30% at 50% 55%, rgba(245, 224, 220, 0.06), transparent 75%)",
      "rim-light": "inset 0 1px 0 rgba(205, 214, 244, 0.06)",
      "rim-light-strong": "inset 0 1px 0 rgba(245, 194, 231, 0.22), inset 0 -1px 0 rgba(17, 17, 27, 0.45)",
      "selection-bg": "rgba(203, 166, 247, 0.34)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(12, 12, 22, 0.55), 0 0 0 1px rgba(203, 166, 247, 0.07)",
      "shadow-md": "0 12px 30px -12px rgba(12, 12, 22, 0.75), 0 2px 6px -2px rgba(24, 24, 37, 0.50), 0 0 0 1px rgba(203, 166, 247, 0.08)",
      "shadow-lg": "0 26px 54px -18px rgba(12, 12, 22, 0.85), 0 8px 16px -6px rgba(24, 24, 37, 0.55), 0 0 0 1px rgba(203, 166, 247, 0.12)",
      "shadow-card-hover": "0 18px 38px -14px rgba(12, 12, 22, 0.80), 0 4px 10px -2px rgba(24, 24, 37, 0.50), 0 0 0 1px rgba(203, 166, 247, 0.48), 0 0 34px rgba(245, 194, 231, 0.24)",
      "well-shadow": "inset 0 2px 12px rgba(8, 8, 14, 0.72), inset 0 -1px 0 rgba(205, 214, 244, 0.05), inset 0 0 0 1px rgba(203, 166, 247, 0.07)",
      "composer-ring": "inset 0 0 0 1px rgba(203, 166, 247, 0.24), inset 0 1px 0 rgba(205, 214, 244, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(203, 166, 247, 0.88), inset 0 1px 0 rgba(245, 224, 220, 0.24), 0 0 0 3px rgba(203, 166, 247, 0.20), 0 12px 32px -8px rgba(245, 194, 231, 0.36), 0 0 46px rgba(203, 166, 247, 0.12)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.34",
      "line-height-normal": "1.62",
      "line-height-relaxed": "1.78",
      "letter-spacing-tight": "-0.006em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "8px",
      "radius-md": "12px",
      "radius-lg": "18px",
      "radius-pill": "999px",
      "border-radius": "12px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.16s cubic-bezier(0.4, 0, 0.2, 1)",
      "transition-normal": "0.26s cubic-bezier(0.4, 0, 0.2, 1)",
      "transition-slow": "0.38s cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.2s ease"
    },
    "layout": {
      "scrollbar-width": "10px",
      "scrollbar-thumb-bg": "rgba(203, 166, 247, 0.16)",
      "scrollbar-thumb-hover-bg": "rgba(245, 194, 231, 0.48)",
      "focus-ring": "0 0 0 1px rgba(245, 224, 220, 0.55), 0 0 0 3px rgba(203, 166, 247, 0.55), 0 6px 20px rgba(245, 194, 231, 0.28)",
      "chat-max-width": "820px",
      "turn-gap": "20px",
      "composer-min-height": "72px",
      "composer-padding-y": "16px",
      "canvas-padding-inline": "38px",
      "sidebar-item-padding-y": "8px"
    },
    "border": {
      "border-thin": "1px"
    },
    "icon": {
      "icon-md": "16px",
      "icon-lg": "18px"
    },
    "control": {
      "control-height-md": "34px",
      "control-height-lg": "40px"
    },
    "component": {
      "card-padding": "20px",
      "menu-item-padding-y": "9px",
      "menu-item-padding-x": "14px"
    }
  }
}

{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "bunker",
    "name": "Bunker",
    "author": "Claudette",
    "version": "2.1.0",
    "scheme": "dark",
    "description": "Raw concrete, safety orange, hard drop-shadows. Brutalist by architectural intent.",
    "stylesheet": "stylesheets/bunker.css",
    "preview": {
      "background": "#141414",
      "surface": "#2b2b2b",
      "accent": "#ff5b13",
      "text": "#eceae4"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#141414",
      "sidebar-bg": "#1c1c1c",
      "sidebar-border": "#000000",
      "panel-bg": "#1c1c1c",
      "surface-bg": "#2b2b2b",
      "sunken-bg": "#0a0a0a",
      "text-primary": "#eceae4",
      "text-muted": "#b6b3ac",
      "text-dim": "#868280",
      "text-faint": "#5a5754",
      "text-separator": "#3a3734",
      "accent-primary": "#ff5b13",
      "accent-primary-rgb": "255, 91, 19",
      "accent-dim": "#c44209",
      "accent-bg": "rgba(255, 91, 19, 0.12)",
      "accent-bg-strong": "rgba(255, 91, 19, 0.24)",
      "accent-glow": "0 0 0 2px #ff5b13",
      "hover-bg": "rgba(236, 234, 228, 0.06)",
      "hover-bg-subtle": "rgba(236, 234, 228, 0.03)",
      "selected-bg": "rgba(255, 91, 19, 0.16)",
      "divider": "#000000",
      "status-running": "#ff5b13",
      "status-idle": "#868280",
      "status-stopped": "#d72638",
      "badge-done": "#cfcab8",
      "badge-plan": "#8a8f7a",
      "badge-ask": "#ffb000",
      "diff-added-bg": "rgba(150, 180, 90, 0.14)",
      "diff-removed-bg": "rgba(215, 38, 56, 0.16)",
      "diff-added-text": "#b4c97a",
      "diff-removed-text": "#e85a68",
      "diff-hunk-header": "#ff5b13",
      "diff-line-number": "#5a5754",
      "chat-user-bg": "rgba(236, 234, 228, 0.03)",
      "chat-system-bg": "rgba(255, 91, 19, 0.06)",
      "chat-input-bg": "#0a0a0a",
      "chat-header-bg": "#1a1a1a",
      "terminal-tab-bg": "#1c1c1c",
      "terminal-tab-active-bg": "#2b2b2b",
      "terminal-bg": "#0a0a0a",
      "terminal-fg": "#eceae4",
      "terminal-cursor": "#ff5b13",
      "terminal-selection": "rgba(255, 91, 19, 0.30)",
      "toolbar-active": "rgba(255, 91, 19, 0.20)",
      "toolbar-active-text": "#ff5b13",
      "error-bg": "rgba(215, 38, 56, 0.14)",
      "error-border": "rgba(215, 38, 56, 0.60)",
      "error-hover": "rgba(215, 38, 56, 0.22)",
      "overlay-bg": "rgba(0, 0, 0, 0.76)",
      "overlay-bg-heavy": "rgba(0, 0, 0, 0.92)",
      "canvas-atmosphere": "linear-gradient(172deg, rgba(255, 255, 255, 0.045) 0%, rgba(255, 255, 255, 0.018) 28%, transparent 55%, rgba(0, 0, 0, 0.32) 100%)",
      "rim-light": "inset 0 1px 0 rgba(255, 255, 255, 0.05)",
      "rim-light-strong": "inset 0 1px 0 rgba(255, 255, 255, 0.09)",
      "selection-bg": "rgba(255, 91, 19, 0.38)"
    },
    "elevation": {
      "shadow-sm": "0 2px 0 #000000",
      "shadow-md": "0 4px 0 #000000",
      "shadow-lg": "0 6px 0 #000000",
      "shadow-card-hover": "0 4px 0 #ff5b13",
      "well-shadow": "inset 0 3px 0 #000000, inset 0 -1px 0 rgba(255, 255, 255, 0.03)",
      "composer-ring": "inset 0 0 0 2px #000000, inset 0 1px 0 rgba(255, 255, 255, 0.04)",
      "composer-ring-focus": "inset 0 0 0 3px #ff5b13"
    },
    "typography": {
      "font-size-sm": "10px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "17px",
      "font-weight-regular": "500",
      "font-weight-medium": "600",
      "font-weight-semibold": "700",
      "font-weight-bold": "800",
      "line-height-tight": "1.12",
      "line-height-normal": "1.42",
      "line-height-relaxed": "1.58",
      "letter-spacing-tight": "-0.02em",
      "letter-spacing-wide": "0.14em"
    },
    "radius": {
      "radius-sm": "0px",
      "radius-md": "0px",
      "radius-lg": "0px",
      "radius-pill": "0px",
      "border-radius": "0px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "14px",
      "space-lg": "20px",
      "space-xl": "32px"
    },
    "layout": {
      "scrollbar-width": "12px",
      "scrollbar-thumb-bg": "#2b2b2b",
      "scrollbar-thumb-hover-bg": "#ff5b13",
      "focus-ring": "0 0 0 3px #ff5b13",
      "chat-max-width": "100%",
      "turn-gap": "10px",
      "canvas-padding-inline": "24px",
      "composer-min-height": "52px",
      "composer-padding-y": "12px",
      "sidebar-item-padding-y": "5px",
      "sidebar-item-gap": "0px"
    },
    "border": {
      "border-thin": "2px",
      "border-medium": "3px",
      "border-thick": "4px"
    },
    "control": {
      "control-height-sm": "26px",
      "control-height-md": "36px",
      "control-height-lg": "44px"
    },
    "icon": {
      "icon-sm": "12px",
      "icon-md": "14px",
      "icon-lg": "16px"
    },
    "motion": {
      "transition-fast": "0.06s steps(1, end)",
      "transition-normal": "0.08s steps(1, end)",
      "transition-slow": "0.14s steps(2, end)",
      "transition-instant": "0s",
      "transition-hover": "0s",
      "transition-emphasis": "0.06s steps(1, end)",
      "ease-standard": "steps(1, end)",
      "ease-accelerate": "steps(1, end)",
      "ease-decelerate": "steps(1, end)"
    },
    "shape": {
      "user-msg-padding": "12px 16px",
      "user-msg-chrome": "inset 0 0 0 2px #000, 4px 4px 0 rgba(0, 0, 0, 0.80)",
      "user-msg-bg": "rgba(255, 91, 19, 0.04)",
      "user-msg-margin-top": "30px",
      "role-label-glyph": "'//'",
      "role-label-glyph-color": "#ff5b13",
      "role-label-transform": "uppercase",
      "role-label-weight": "700",
      "chat-header-chrome": "0 2px 0 #000",
      "sidebar-selected-chrome": "inset 0 0 0 2px #000, 3px 3px 0 rgba(0, 0, 0, 0.70)",
      "panel-header-chrome": "0 2px 0 #000"
    }
  }
}

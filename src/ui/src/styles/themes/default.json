{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "default",
    "name": "Default",
    "author": "James Brink",
    "version": "2.0.0",
    "scheme": "dark",
    "description": "Warm chrome, dark terminal chat \u2014 Ristretto-inspired amber (#f9cc6c) on rosewood, hand-crafted linen texture and wax-seal edges.",
    "stylesheet": "stylesheets/default.css",
    "preview": {
      "background": "#2c2525",
      "surface": "#453a3a",
      "accent": "#f9cc6c",
      "text": "#f1e5e7"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#2c2525",
      "sidebar-bg": "#3a3131",
      "sidebar-border": "#5b4d4d",
      "panel-bg": "#3a3131",
      "surface-bg": "#453a3a",
      "sunken-bg": "#1f1a1a",
      "text-primary": "#f1e5e7",
      "text-muted": "#d0c4c6",
      "text-dim": "#b0a4a6",
      "text-faint": "#907e80",
      "text-separator": "#5b4d4d",
      "accent-primary": "#f9cc6c",
      "accent-primary-rgb": "249, 204, 108",
      "accent-dim": "#d4a84a",
      "accent-bg": "rgba(249, 204, 108, 0.10)",
      "accent-bg-strong": "rgba(249, 204, 108, 0.22)",
      "accent-glow": "0 0 1px rgba(255, 238, 190, 0.70), 0 0 10px rgba(249, 204, 108, 0.45), 0 0 28px rgba(249, 204, 108, 0.20), 0 0 60px rgba(212, 168, 74, 0.10)",
      "hover-bg": "rgba(255, 232, 220, 0.07)",
      "hover-bg-subtle": "rgba(255, 232, 220, 0.035)",
      "selected-bg": "rgba(249, 204, 108, 0.15)",
      "divider": "#5b4d4d",
      "status-running": "#f9cc6c",
      "status-idle": "#b0a4a6",
      "status-stopped": "#fd6883",
      "badge-done": "#adda78",
      "badge-plan": "#a8a9eb",
      "badge-ask": "#f38d70",
      "diff-added-bg": "rgba(173, 218, 120, 0.14)",
      "diff-removed-bg": "rgba(253, 104, 131, 0.14)",
      "diff-added-text": "#adda78",
      "diff-removed-text": "#fd6883",
      "diff-hunk-header": "#85dacc",
      "diff-line-number": "#907e80",
      "chat-user-bg": "rgba(255, 240, 235, 0.04)",
      "chat-system-bg": "rgba(249, 204, 108, 0.06)",
      "chat-input-bg": "#1f1a1a",
      "chat-header-bg": "#332a2a",
      "terminal-tab-bg": "#332a2a",
      "terminal-tab-active-bg": "#453a3a",
      "terminal-bg": "#1a1515",
      "terminal-fg": "#f1e5e7",
      "terminal-cursor": "#f9cc6c",
      "terminal-selection": "rgba(249, 204, 108, 0.28)",
      "toolbar-active": "rgba(249, 204, 108, 0.18)",
      "toolbar-active-text": "#f9cc6c",
      "error-bg": "rgba(253, 104, 131, 0.10)",
      "error-border": "rgba(253, 104, 131, 0.40)",
      "error-hover": "rgba(253, 104, 131, 0.16)",
      "overlay-bg": "rgba(20, 14, 14, 0.68)",
      "overlay-bg-heavy": "rgba(20, 14, 14, 0.88)",
      "canvas-atmosphere": "radial-gradient(90% 55% at 50% -6%, rgba(249, 204, 108, 0.075), transparent 58%), radial-gradient(70% 42% at 50% 0%, rgba(243, 141, 112, 0.035), transparent 72%), radial-gradient(120% 80% at 50% 100%, rgba(20, 14, 14, 0.50), transparent 60%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 160'><filter id='p'><feTurbulence type='fractalNoise' baseFrequency='0.70' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.96  0 0 0 0 0.78  0 0 0 0 0.60  0 0 0 0.05 0'/></filter><rect width='100%25' height='100%25' filter='url(%23p)'/></svg>\")",
      "rim-light": "inset 0 1px 0 rgba(255, 238, 220, 0.055)",
      "rim-light-strong": "inset 0 1px 0 rgba(249, 204, 108, 0.20), inset 0 -1px 0 rgba(20, 14, 14, 0.50)",
      "selection-bg": "rgba(249, 204, 108, 0.32)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(20, 14, 14, 0.55), 0 0 0 1px rgba(249, 204, 108, 0.04)",
      "shadow-md": "0 10px 28px -12px rgba(20, 14, 14, 0.75), 0 2px 6px -2px rgba(44, 32, 32, 0.50), 0 0 0 1px rgba(249, 204, 108, 0.05)",
      "shadow-lg": "0 24px 52px -18px rgba(20, 14, 14, 0.85), 0 8px 16px -6px rgba(44, 32, 32, 0.55), 0 0 0 1px rgba(249, 204, 108, 0.08)",
      "shadow-card-hover": "0 16px 36px -14px rgba(20, 14, 14, 0.80), 0 4px 10px -2px rgba(44, 32, 32, 0.55), 0 0 0 1px rgba(249, 204, 108, 0.36), 0 0 28px rgba(249, 204, 108, 0.16)",
      "well-shadow": "inset 0 2px 10px rgba(12, 8, 8, 0.72), inset 0 -1px 0 rgba(255, 238, 220, 0.045), inset 0 0 0 1px rgba(249, 204, 108, 0.05)",
      "composer-ring": "inset 0 0 0 1px rgba(212, 168, 74, 0.22), inset 0 1px 0 rgba(255, 238, 220, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(249, 204, 108, 0.80), inset 0 1px 0 rgba(255, 238, 200, 0.22), 0 0 0 3px rgba(249, 204, 108, 0.16), 0 10px 28px -8px rgba(212, 168, 74, 0.34), 0 0 40px rgba(249, 204, 108, 0.10)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.55",
      "line-height-relaxed": "1.7",
      "letter-spacing-tight": "-0.01em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "4px",
      "radius-md": "8px",
      "radius-lg": "14px",
      "radius-pill": "999px",
      "border-radius": "8px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.12s ease",
      "transition-normal": "0.2s ease",
      "transition-slow": "0.3s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(249, 204, 108, 0.14)",
      "scrollbar-thumb-hover-bg": "rgba(249, 204, 108, 0.42)",
      "focus-ring": "0 0 0 1px rgba(255, 238, 200, 0.50), 0 0 0 3px rgba(249, 204, 108, 0.50), 0 6px 18px rgba(212, 168, 74, 0.22)"
    }
  }
}

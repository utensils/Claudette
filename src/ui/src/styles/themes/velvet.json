{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "velvet",
    "name": "Velvet",
    "author": "James Brink",
    "version": "2.0.0",
    "scheme": "dark",
    "description": "Midnight opera \u2014 theatrical champagne-gold spotlight on deep indigo velvet, with a crescent moon watching from the wings.",
    "stylesheet": "stylesheets/velvet.css",
    "preview": {
      "background": "#0a0c1e",
      "surface": "#1c1f3e",
      "accent": "#dcc080",
      "text": "#f0e8d4"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#0a0c1e",
      "sidebar-bg": "#0d1028",
      "sidebar-border": "#1e2146",
      "panel-bg": "#131635",
      "surface-bg": "#1c1f3e",
      "sunken-bg": "#050617",
      "text-primary": "#f0e8d4",
      "text-muted": "#c6bea9",
      "text-dim": "#8e876f",
      "text-faint": "#605a4d",
      "text-separator": "#2a2d50",
      "accent-primary": "#dcc080",
      "accent-primary-rgb": "220, 192, 128",
      "accent-dim": "#a89260",
      "accent-bg": "rgba(220, 192, 128, 0.09)",
      "accent-bg-strong": "rgba(220, 192, 128, 0.22)",
      "accent-glow": "0 0 1px rgba(255, 246, 214, 0.70), 0 0 12px rgba(220, 192, 128, 0.55), 0 0 34px rgba(220, 192, 128, 0.22), 0 0 72px rgba(235, 210, 150, 0.08)",
      "hover-bg": "rgba(240, 232, 212, 0.045)",
      "hover-bg-subtle": "rgba(240, 232, 212, 0.025)",
      "selected-bg": "rgba(220, 192, 128, 0.15)",
      "divider": "#1e2146",
      "status-running": "#dcc080",
      "status-idle": "#8e876f",
      "status-stopped": "#a04055",
      "badge-done": "#86a894",
      "badge-plan": "#b5a9d4",
      "badge-ask": "#d4b070",
      "diff-added-bg": "rgba(134, 168, 148, 0.12)",
      "diff-removed-bg": "rgba(160, 64, 85, 0.14)",
      "diff-added-text": "#a0c0ac",
      "diff-removed-text": "#c07080",
      "diff-hunk-header": "#d4b070",
      "diff-line-number": "#605a4d",
      "chat-user-bg": "rgba(240, 232, 212, 0.022)",
      "chat-system-bg": "rgba(220, 192, 128, 0.045)",
      "chat-input-bg": "#050617",
      "chat-header-bg": "#0d1028",
      "terminal-tab-bg": "#0d1028",
      "terminal-tab-active-bg": "#1c1f3e",
      "terminal-bg": "#050617",
      "terminal-fg": "#f0e8d4",
      "terminal-cursor": "#dcc080",
      "terminal-selection": "rgba(220, 192, 128, 0.22)",
      "toolbar-active": "rgba(220, 192, 128, 0.22)",
      "toolbar-active-text": "#ecd498",
      "error-bg": "rgba(160, 64, 85, 0.12)",
      "error-border": "rgba(160, 64, 85, 0.40)",
      "error-hover": "rgba(160, 64, 85, 0.18)",
      "overlay-bg": "rgba(3, 4, 12, 0.70)",
      "overlay-bg-heavy": "rgba(3, 4, 12, 0.88)",
      "canvas-atmosphere": "radial-gradient(16% 12% at 50% -4%, rgba(255, 234, 170, 0.42), transparent 72%), radial-gradient(36% 30% at 50% 2%, rgba(220, 192, 128, 0.18), transparent 74%), radial-gradient(140% 110% at 50% 60%, transparent 28%, rgba(2, 3, 12, 0.78) 100%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'><filter id='v'><feTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='2' stitchTiles='stitch' seed='9'/><feColorMatrix values='0 0 0 0 0.86  0 0 0 0 0.75  0 0 0 0 0.50  0 0 0 0.035 0'/></filter><rect width='100%25' height='100%25' filter='url(%23v)'/></svg>\")",
      "rim-light": "inset 0 1px 0 rgba(240, 232, 212, 0.04)",
      "rim-light-strong": "inset 0 1px 0 rgba(220, 192, 128, 0.22), inset 0 -1px 0 rgba(2, 3, 12, 0.65)",
      "selection-bg": "rgba(220, 192, 128, 0.30)"
    },
    "elevation": {
      "shadow-sm": "0 1px 2px rgba(2, 3, 12, 0.60), 0 0 0 1px rgba(220, 192, 128, 0.04)",
      "shadow-md": "0 12px 34px -14px rgba(2, 3, 12, 0.85), 0 2px 6px -2px rgba(10, 12, 32, 0.55), 0 0 0 1px rgba(220, 192, 128, 0.05)",
      "shadow-lg": "0 30px 60px -22px rgba(2, 3, 12, 0.95), 0 10px 20px -6px rgba(10, 12, 32, 0.65), 0 0 0 1px rgba(220, 192, 128, 0.09)",
      "shadow-card-hover": "0 22px 44px -18px rgba(2, 3, 12, 0.90), 0 6px 12px -2px rgba(10, 12, 32, 0.60), 0 0 0 1px rgba(220, 192, 128, 0.42), 0 0 30px rgba(220, 192, 128, 0.14)",
      "well-shadow": "inset 0 2px 12px rgba(2, 3, 12, 0.78), inset 0 -1px 0 rgba(240, 232, 212, 0.03), inset 0 0 0 1px rgba(220, 192, 128, 0.05)",
      "composer-ring": "inset 0 0 0 1px rgba(220, 192, 128, 0.20), inset 0 1px 0 rgba(240, 232, 212, 0.05)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(220, 192, 128, 0.85), inset 0 1px 0 rgba(255, 246, 214, 0.22), 0 0 0 3px rgba(220, 192, 128, 0.14), 0 12px 32px -8px rgba(220, 192, 128, 0.26), 0 0 48px rgba(220, 192, 128, 0.08)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.6",
      "line-height-relaxed": "1.78",
      "letter-spacing-tight": "-0.008em",
      "letter-spacing-wide": "0.08em"
    },
    "radius": {
      "radius-sm": "2px",
      "radius-md": "4px",
      "radius-lg": "8px",
      "radius-pill": "999px",
      "border-radius": "4px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "18px",
      "space-xl": "26px"
    },
    "motion": {
      "transition-fast": "0.18s cubic-bezier(0.22, 0.75, 0.22, 1)",
      "transition-normal": "0.28s cubic-bezier(0.22, 0.75, 0.22, 1)",
      "transition-slow": "0.42s cubic-bezier(0.22, 0.75, 0.22, 1)",
      "ease-standard": "cubic-bezier(0.22, 0.75, 0.22, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)",
      "transition-hover": "0.22s cubic-bezier(0.22, 0.75, 0.22, 1)",
      "transition-emphasis": "0.8s ease"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(220, 192, 128, 0.12)",
      "scrollbar-thumb-hover-bg": "rgba(220, 192, 128, 0.42)",
      "focus-ring": "0 0 0 1px rgba(255, 246, 214, 0.55), 0 0 0 3px rgba(220, 192, 128, 0.55), 0 6px 18px rgba(220, 192, 128, 0.22)",
      "chat-max-width": "780px",
      "turn-gap": "22px",
      "canvas-padding-inline": "44px",
      "composer-min-height": "72px",
      "composer-padding-y": "16px",
      "sidebar-item-padding-y": "8px"
    },
    "border": {
      "border-thin": "1px",
      "border-medium": "1px"
    },
    "icon": {
      "icon-md": "16px",
      "icon-lg": "18px"
    },
    "control": {
      "control-height-md": "32px",
      "control-height-lg": "40px"
    },
    "component": {
      "card-padding": "20px",
      "menu-item-padding-y": "9px",
      "menu-item-padding-x": "16px"
    }
  }
}

      "shadow-lg": "0 24px 52px -18px rgba(18, 22, 28, 0.90), 0 8px 16px -6px rgba(33, 37, 45, 0.60), 0 0 0 1px rgba(136, 192, 208, 0.09)",
      "shadow-card-hover": "0 16px 36px -14px rgba(18, 22, 28, 0.85), 0 4px 10px -2px rgba(33, 37, 45, 0.58), 0 0 0 1px rgba(136, 192, 208, 0.42), 0 0 28px rgba(129, 161, 193, 0.16)",
      "well-shadow": "inset 0 2px 10px rgba(12, 14, 19, 0.75), inset 0 -1px 0 rgba(236, 239, 244, 0.04), inset 0 0 0 1px rgba(136, 192, 208, 0.06)",
      "composer-ring": "inset 0 0 0 1px rgba(136, 192, 208, 0.22), inset 0 1px 0 rgba(236, 239, 244, 0.06)",
      "composer-ring-focus": "inset 0 0 0 1px rgba(136, 192, 208, 0.85), inset 0 1px 0 rgba(236, 239, 244, 0.22), 0 0 0 3px rgba(136, 192, 208, 0.18), 0 10px 28px -8px rgba(94, 129, 172, 0.32), 0 0 40px rgba(129, 161, 193, 0.12)"
    },
    "typography": {
      "font-size-sm": "11px",
      "font-size-base": "13px",
      "font-size-md": "14px",
      "font-size-lg": "16px",
      "font-weight-regular": "400",
      "font-weight-medium": "500",
      "font-weight-semibold": "600",
      "font-weight-bold": "700",
      "line-height-tight": "1.3",
      "line-height-normal": "1.58",
      "line-height-relaxed": "1.72",
      "letter-spacing-tight": "-0.008em",
      "letter-spacing-wide": "0.05em"
    },
    "radius": {
      "radius-sm": "3px",
      "radius-md": "5px",
      "radius-lg": "9px",
      "radius-pill": "999px",
      "border-radius": "5px"
    },
    "spacing": {
      "space-xs": "4px",
      "space-sm": "8px",
      "space-md": "12px",
      "space-lg": "16px",
      "space-xl": "24px"
    },
    "motion": {
      "transition-fast": "0.12s ease",
      "transition-normal": "0.20s ease",
      "transition-slow": "0.30s ease",
      "ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "ease-accelerate": "cubic-bezier(0.4, 0, 1, 1)",
      "ease-decelerate": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "layout": {
      "scrollbar-width": "8px",
      "scrollbar-thumb-bg": "rgba(136, 192, 208, 0.16)",
      "scrollbar-thumb-hover-bg": "rgba(136, 192, 208, 0.44)",
      "focus-ring": "0 0 0 1px rgba(236, 239, 244, 0.55), 0 0 0 3px rgba(136, 192, 208, 0.55), 0 6px 18px rgba(94, 129, 172, 0.26)",
      "chat-max-width": "960px",
      "turn-gap": "16px",
      "composer-min-height": "62px",
      "composer-padding-y": "14px",
      "canvas-padding-inline": "32px",
      "sidebar-item-padding-y": "6px"
    },
    "border": {
      "border-thin": "1px"
    },
    "icon": {
      "icon-md": "16px"
    },
    "control": {
      "control-height-md": "32px"
    }
  }

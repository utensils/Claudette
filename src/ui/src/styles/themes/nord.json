{
  "$schema": "./theme.schema.json",
  "manifest": {
    "id": "nord",
    "name": "Nord",
    "author": "Arctic Ice Studio (port)",
    "version": "1.0.0",
    "scheme": "dark",
    "description": "Canonical Nord — Polar Night slate (#2e3440) beneath Snow Storm text, with Frost aurora (#88c0d0 / #81a1c1) drifting across a cool Scandinavian twilight.",
    "stylesheet": "stylesheets/nord.css",
    "preview": {
      "background": "#2e3440",
      "surface": "#434c5e",
      "accent": "#88c0d0",
      "text": "#eceff4"
    }
  },
  "tokens": {
    "color": {
      "color-scheme": "dark",
      "app-bg": "#2e3440",
      "sidebar-bg": "#292e39",
      "sidebar-border": "#3b4252",
      "panel-bg": "#3b4252",
      "surface-bg": "#434c5e",
      "sunken-bg": "#21252d",
      "text-primary": "#eceff4",
      "text-muted": "#d8dee9",
      "text-dim": "#a6adbb",
      "text-faint": "#6b7489",
      "text-separator": "#4c566a",
      "accent-primary": "#88c0d0",
      "accent-primary-rgb": "136, 192, 208",
      "accent-dim": "#5e81ac",
      "accent-bg": "rgba(136, 192, 208, 0.10)",
      "accent-bg-strong": "rgba(136, 192, 208, 0.22)",
      "accent-glow": "0 0 1px rgba(236, 239, 244, 0.70), 0 0 12px rgba(136, 192, 208, 0.50), 0 0 30px rgba(129, 161, 193, 0.26), 0 0 64px rgba(94, 129, 172, 0.12)",
      "hover-bg": "rgba(236, 239, 244, 0.05)",
      "hover-bg-subtle": "rgba(236, 239, 244, 0.028)",
      "selected-bg": "rgba(136, 192, 208, 0.16)",
      "divider": "#3b4252",
      "status-running": "#a3be8c",
      "status-idle": "#a6adbb",
      "status-stopped": "#bf616a",
      "badge-done": "#a3be8c",
      "badge-plan": "#b48ead",
      "badge-ask": "#ebcb8b",
      "diff-added-bg": "rgba(163, 190, 140, 0.14)",
      "diff-removed-bg": "rgba(191, 97, 106, 0.14)",
      "diff-added-text": "#a3be8c",
      "diff-removed-text": "#bf616a",
      "diff-hunk-header": "#ebcb8b",
      "diff-line-number": "#6b7489",
      "chat-user-bg": "rgba(236, 239, 244, 0.025)",
      "chat-system-bg": "rgba(136, 192, 208, 0.06)",
      "chat-input-bg": "#21252d",
      "chat-header-bg": "#292e39",
      "terminal-tab-bg": "#292e39",
      "terminal-tab-active-bg": "#434c5e",
      "terminal-bg": "#21252d",
      "terminal-fg": "#eceff4",
      "terminal-cursor": "#88c0d0",
      "terminal-selection": "rgba(136, 192, 208, 0.28)",
      "toolbar-active": "rgba(136, 192, 208, 0.18)",
      "toolbar-active-text": "#8fbcbb",
      "error-bg": "rgba(191, 97, 106, 0.10)",
      "error-border": "rgba(191, 97, 106, 0.40)",
      "error-hover": "rgba(191, 97, 106, 0.16)",
      "overlay-bg": "rgba(22, 26, 33, 0.70)",
      "overlay-bg-heavy": "rgba(22, 26, 33, 0.90)",
      "canvas-atmosphere": "radial-gradient(90% 50% at 50% -4%, rgba(136, 192, 208, 0.10), transparent 60%), radial-gradient(70% 30% at 20% 0%, rgba(129, 161, 193, 0.08), transparent 70%), radial-gradient(80% 40% at 80% 0%, rgba(180, 142, 173, 0.06), transparent 72%), radial-gradient(120% 80% at 50% 100%, rgba(22, 26, 33, 0.55), transparent 60%), url(\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch' seed='2'/><feColorMatrix values='0 0 0 0 0.92  0 0 0 0 0.94  0 0 0 0 0.96  0 0 0 0.04 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>\")",
      "rim-light": "inset 0 1px 0 rgba(236, 239, 244, 0.05)",
      "rim-light-strong": "inset 0 1px 0 rgba(136, 192, 208, 0.22), inset 0 -1px 0 rgba(22, 26, 33, 0.50)",
      "selection-bg": "rgba(136, 192, 208, 0.32)"
